# Load ignored local environment variables (for example SONAR_TOKEN) without
# printing their values, then activate an existing project virtual environment.
# This file intentionally performs no installation or network access.
dotenv_if_exists .env
watch_file requirements.txt
watch_file requirements-dev.txt

if [ -d .venv ]; then
  source .venv/bin/activate
elif [ -d venv ]; then
  source venv/bin/activate
fi

if [ -n "${VIRTUAL_ENV:-}" ]; then
  python scripts/sync_dev_environment.py --check || true
else
  echo "DICOM Viewer: no project venv found; create .venv and run the documented setup."
fi
