#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PY_BIN=""

if [[ -x "$REPO_ROOT/.venv/bin/python" ]]; then
  PY_BIN="$REPO_ROOT/.venv/bin/python"
elif [[ -x "$REPO_ROOT/.venv/Scripts/python.exe" ]]; then
  PY_BIN="$REPO_ROOT/.venv/Scripts/python.exe"
elif [[ -x "$REPO_ROOT/venv/bin/python" ]]; then
  PY_BIN="$REPO_ROOT/venv/bin/python"
elif [[ -x "$REPO_ROOT/venv/Scripts/python.exe" ]]; then
  PY_BIN="$REPO_ROOT/venv/Scripts/python.exe"
else
  echo "[security hook] No project Python found under .venv or venv." >&2
  exit 1
fi

# Prune local backups/ by branch (non-fatal: never block the commit).
# Tracked: drop if >10 commits since last touch, or if >10 commits landed in the
# last PRUNE_DAYS days and intent is older than PRUNE_DAYS. Untracked: intent
# older than PRUNE_DAYS (embedded date vs mtime min). Then stage removals.
BRANCH="$(git branch --show-current 2>/dev/null || true)"
PRUNE_DAYS=0
case "$BRANCH" in
  main) PRUNE_DAYS=3 ;;
  WIP) PRUNE_DAYS=3 ;;
esac
if [[ "$PRUNE_DAYS" -gt 0 ]]; then
  if ! "$PY_BIN" "$REPO_ROOT/scripts/git-hook-prune-backups.py" --days "$PRUNE_DAYS" --max-commits 10; then
    echo "[backup hook] prune script failed (continuing with security gate)." >&2
  fi
  if ! git -C "$REPO_ROOT" add -u -- backups; then
    echo "[backup hook] git add -u backups/ failed (continuing with security gate)." >&2
  fi
fi

exec "$PY_BIN" "$REPO_ROOT/scripts/git-hook-security-gate.py" --hook-type pre-commit
