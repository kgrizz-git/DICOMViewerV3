#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
PY_BIN=""

if [[ -x "$REPO_ROOT/.venv/bin/python" ]]; then
  PY_BIN="$REPO_ROOT/.venv/bin/python"
elif [[ -x "$REPO_ROOT/.venv/Scripts/python.exe" ]]; then
  PY_BIN="$REPO_ROOT/.venv/Scripts/python.exe"
elif [[ -x "$REPO_ROOT/venv/bin/python" ]]; then
  PY_BIN="$REPO_ROOT/venv/bin/python"
elif [[ -x "$REPO_ROOT/venv/Scripts/python.exe" ]]; then
  PY_BIN="$REPO_ROOT/venv/Scripts/python.exe"
else
  echo "[security hook] No project Python found under .venv or venv." >&2
  exit 1
fi

# Git supplies proposed ref updates on stdin. Capture them once so both the
# metadata/privacy guard and the main-only full security gate see identical
# input; reading stdin in the first child would otherwise starve the second.
PUSH_UPDATES="$(cat)"

echo "[metadata] Validating proposed refs, authors, and remote URL..."
printf '%s\n' "$PUSH_UPDATES" | "$PY_BIN" "$REPO_ROOT/scripts/git_hook_pre_push_privacy.py" \
  --root "$REPO_ROOT" \
  --remote-name "${1:-}" \
  --remote-url "${2:-}" || exit 1

echo "[phi] Scanning the complete tracked tree..."
"$PY_BIN" "$REPO_ROOT/scripts/check_no_phi_artifacts.py" --root "$REPO_ROOT" || exit 1

echo "[privacy] Scanning all covered output and logging sinks..."
"$PY_BIN" "$REPO_ROOT/scripts/git_hook_privacy_checks.py" --all --critical || exit 1

echo "[secrets] Scanning reachable history with mandatory Gitleaks..."
"$PY_BIN" "$REPO_ROOT/scripts/check_gitleaks_history.py" --root "$REPO_ROOT" || exit 1

# Static type gate: fail on basedpyright errors, matching CI. Warnings are
# reported but do not block pushes until the repo warning baseline is cleared.
echo "[pyright] Running basedpyright error gate..."
"$PY_BIN" "$REPO_ROOT/scripts/check_basedpyright_errors.py" || exit 1

# Coverage gate (warn only — does not block push or upload results).
# Threshold: 50 %. Run pytest-cov locally and parse TOTAL %.
echo "[coverage] Running pytest --cov=src..."
COV_OUTPUT="$("$PY_BIN" -m pytest tests --cov=src --cov-report=term -q --no-header 2>&1)" || true
TOTAL_PCT=$(echo "$COV_OUTPUT" | awk '/^TOTAL/{gsub(/%/,""); print $NF}')
if [[ -n "$TOTAL_PCT" ]]; then
  echo "[coverage] Total coverage: ${TOTAL_PCT}%"
  if (( $(echo "$TOTAL_PCT < 50" | bc -l 2>/dev/null || echo 0) )); then
    echo "[coverage] ⚠  Coverage ${TOTAL_PCT}% is below the 50 % threshold — push allowed, but please improve coverage." >&2
  else
    echo "[coverage] Coverage meets the 50 % threshold."
  fi
else
  echo "[coverage] Could not determine coverage percentage (continuing)." >&2
fi

# Complexity gate (warn only — does not block push).
# Mirrors CI lizard.yml. Flags functions with CCN >= 15 or NLOC >= 200.
echo "[complexity] Running lizard..."
LIZARD_OUT="$("$PY_BIN" -m lizard src/ --CCN 15 --length 200 -w 2>&1)" || true
WARN_COUNT=$(grep -c "warning:" <<<"$LIZARD_OUT" 2>/dev/null || true)
WARN_COUNT=${WARN_COUNT:-0}
if [[ "$WARN_COUNT" -gt 0 ]]; then
  echo "[complexity] ${WARN_COUNT} high-complexity function(s) — top 5:"
  echo "$LIZARD_OUT" | grep "warning:" | head -5 | while read -r line; do echo "  $line"; done
else
  echo "[complexity] No high-complexity functions found."
fi

printf '%s\n' "$PUSH_UPDATES" | \
  "$PY_BIN" "$REPO_ROOT/scripts/git-hook-security-gate.py" --hook-type pre-push || exit 1

# Hounddog is fast, local-only, and advisory. Run it only after every blocking
# gate passes and only for a proposed main update; never upload or connect it.
if [[ "$PUSH_UPDATES" == *" refs/heads/main "* ]]; then
  echo "[privacy advisory] Running local Hounddog data-flow review..."
  "$PY_BIN" "$REPO_ROOT/scripts/privacy_tool_review.py" hounddog || true
fi

# Only a proposed main update reaches the expensive full scanner above. Once
# it passes, remind the developer when the ignored local SonarQube record is
# missing or older than 30 days. This is advisory because SonarQube and its
# token may intentionally be unavailable on another contributor's machine.
if [[ "$PUSH_UPDATES" == *" refs/heads/main "* ]]; then
  echo "[sonarqube] Checking local Community Build analysis freshness..."
  "$PY_BIN" "$REPO_ROOT/scripts/run_local_sonarqube.py" \
    --check-freshness-days 30 || true
fi

exit 0
