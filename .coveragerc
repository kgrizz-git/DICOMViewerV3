# Coverage configuration for DICOM Viewer V3.
# CI: PYTHONPATH=src python -m pytest tests --cov=src --cov-report=xml --cov-report=term
# Local: python -m pytest tests --cov=src --cov-report=html --cov-report=term
# The coverage.xml artifact is uploaded to Codecov by .github/workflows/tests.yml.

[run]
source = src
branch = True
omit =
    src/__pycache__/*
    src/**/__pycache__/*
    # Generated/extracted third-party bundled inside src/ (none currently, guard for future)
    src/_vendor/*
    # Side-effect-only entry point; exercising it needs a full GUI launch.
    src/main.py

[report]
# Regex exclude — skip __debug__/unreachable branches and typing-only blocks
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
show_missing = False
skip_covered = False
sort = cover

[xml]
output = coverage.xml
