      "categories": [null],
      "identifiers": {},
      "required_identifiers": [],
      "metrics": {"count": "count"},
      "required_metrics": ["count"]
    },
    "architecture.violation": {
      "adapter": "architecture",
      "allow_error": false,
      "categories": ["core-gui", "domain-main", "gui-main", "syntax", "utils-domain"],
      "identifiers": {"module": "module", "repository_path": "repository_path"},
      "required_identifiers": ["repository_path"],
      "metrics": {"line": "count"},
      "required_metrics": ["line"]
    },
    "decoder.copy_failed": {
      "adapter": null,
      "allow_error": true,
      "categories": [null],
      "identifiers": {},
      "required_identifiers": [],
      "metrics": {},
