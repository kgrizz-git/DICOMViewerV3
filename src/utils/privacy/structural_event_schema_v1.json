{
  "schema_version": 1,
  "identifier_validators": {
    "decoder_package": {
      "kind": "enum",
      "values": [
        "pydicom",
        "pylibjpeg",
        "pylibjpeg-libjpeg",
        "pylibjpeg-openjpeg",
        "pylibjpeg-rle",
        "pyjpegls"
      ]
    },
    "format": {
      "kind": "regex_family",
      "pattern": "[A-Za-z0-9][A-Za-z0-9 ._()+/-]{0,95}",
      "family_pattern": "JPEG|JPEGLS|JPEG-LS|RLE|DEFLATED|EXPLICIT VR|IMPLICIT VR|MPEG|HEVC|UNCOMPRESSED"
    },
    "license": {
      "kind": "regex_family",
      "pattern": "[A-Za-z0-9][A-Za-z0-9 ._()+:;/&-]{0,95}",
      "family_pattern": "MIT|BSD|APACHE|GPL|LGPL|AGPL|MPL|EPL|CDDL|ISC|ZLIB|PSF|PYTHON SOFTWARE FOUNDATION|OFL|PUBLIC DOMAIN|UNLICENSE|BOOST|POSTGRESQL|UNKNOWN"
    },
    "module": {
      "kind": "regex",
      "pattern": "(?:src\\.)?(?:core|gui|metadata|qa|roi|tools|utils)(?:\\.[A-Za-z][A-Za-z0-9_]*)*"
    },
    "package": {
      "kind": "regex",
      "pattern": "[A-Za-z0-9][A-Za-z0-9_.-]{0,127}"
    },
    "repository_path": {
      "kind": "regex",
      "pattern": "(?:src/)?(?:core|gui|metadata|qa|roi|tools|utils)/(?:[A-Za-z0-9_.-]+/)*[A-Za-z0-9_.-]+\\.py"
    },
    "source": {
      "kind": "enum",
      "values": ["classifier", "expression", "license-field", "none", "override"]
    },
    "version": {
      "kind": "regex",
      "pattern": "[0-9]+(?:[.][0-9A-Za-z]+)*(?:[-+_.!][0-9A-Za-z]+)*"
    }
  },
  "metric_validators": {
    "boolean": {"kind": "boolean"},
    "count": {"kind": "integer", "minimum": 0, "maximum": 9007199254740991},
    "dimension": {"kind": "integer", "minimum": 0, "maximum": 1000000},
    "duration_ms": {"kind": "number", "minimum": 0, "maximum": 604800000},
    "index": {"kind": "integer", "minimum": 0, "maximum": 9007199254740991},
    "megabytes": {"kind": "number", "minimum": 0, "maximum": 1000000000},
    "number": {"kind": "number", "minimum": -1000000000000000, "maximum": 1000000000000000},
    "shape": {
      "kind": "integer_sequence",
      "minimum_items": 1,
      "maximum_items": 5,
      "minimum": 0,
      "maximum": 1000000
    },
    "spacing_mm": {"kind": "number", "minimum": 0, "maximum": 1000000}
  },
  "operations": {
    "application.startup": {
      "adapter": null,
      "allow_error": true,
      "categories": [null],
      "identifiers": {},
      "required_identifiers": [],
      "metrics": {},
      "required_metrics": []
    },
    "application.unhandled": {
      "adapter": null,
