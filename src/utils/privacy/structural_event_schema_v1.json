    "decoder.package": {
      "adapter": null,
      "allow_error": false,
      "categories": [null, "not-installed"],
      "identifiers": {"package": "decoder_package", "version": "version"},
      "required_identifiers": ["package"],
      "metrics": {},
      "required_metrics": []
    },
    "decoder.syntax_summary": {
      "adapter": null,
      "allow_error": false,
      "categories": ["at-risk", "standard"],
      "identifiers": {"format": "format"},
