    "fusion.series_summary": {
      "adapter": null,
      "allow_error": false,
      "categories": ["ct", "pt"],
      "identifiers": {},
      "required_identifiers": [],
      "metrics": {
        "columns": "dimension",
        "pixel_spacing_mm": "spacing_mm",
        "rows": "dimension",
        "shape": "shape",
        "slice_count": "count",
        "slice_spacing_mm": "spacing_mm",
        "slope": "number"
      },
      "required_metrics": ["columns", "pixel_spacing_mm", "rows", "slice_count"]
    },
    "license.accepted": {
      "adapter": "license",
      "allow_error": false,
      "categories": ["FORBIDDEN", "UNKNOWN"],
      "identifiers": {"license": "license", "package": "package", "source": "source", "version": "version"},
      "required_identifiers": ["license", "package", "source", "version"],
      "metrics": {},
      "required_metrics": []
    },
    "license.obligation": {
      "adapter": "license",
      "allow_error": false,
      "categories": ["OBLIGATION"],
      "identifiers": {"license": "license", "package": "package", "source": "source", "version": "version"},
      "required_identifiers": ["license", "package", "source", "version"],
      "metrics": {},
      "required_metrics": []
    },
    "license.violation": {
      "adapter": "license",
      "allow_error": false,
      "categories": ["FORBIDDEN", "UNKNOWN"],
      "identifiers": {"license": "license", "package": "package", "source": "source", "version": "version"},
      "required_identifiers": ["license", "package", "source", "version"],
      "metrics": {},
      "required_metrics": []
    },
    "performance.mark": {
      "adapter": null,
      "allow_error": false,
      "categories": [],
      "identifiers": {},
      "required_identifiers": [],
      "metrics": {},
      "required_metrics": [],
      "performance_kind": "mark"
    },
    "performance.startup": {
      "adapter": null,
      "allow_error": false,
      "categories": [null],
      "identifiers": {},
      "required_identifiers": [],
      "metrics": {"app_init_ms": "duration_ms", "import_ms": "duration_ms", "total_ms": "duration_ms"},
      "required_metrics": ["app_init_ms", "import_ms", "total_ms"]
