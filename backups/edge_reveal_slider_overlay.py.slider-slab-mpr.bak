"""
Edge-Reveal Slice/Frame Slider Overlay
=======================================

A narrow translucent overlay widget placed along the right edge of an
``ImageViewer`` viewport.  It is hidden by default and only appears when the
pointer enters a configurable proximity zone near the right edge.

Usage
-----
Instantiate with the viewport as parent::

    overlay = EdgeRevealSliderOverlay(image_viewer.viewport())
    overlay.slider_value_changed.connect(on_slider_moved)

Then call ``set_range_and_value`` whenever the displayed slice/frame changes
and ``set_enabled`` when the global View-menu toggle changes.

Inputs
------
- parent : QWidget — must be the ImageViewer *viewport()* so geometry is in
  viewport coordinates.

Outputs
-------
- ``slider_value_changed`` signal (int, 1-based) when the user moves the slider.

Requirements
------------
- PySide6
"""
from __future__ import annotations

from PySide6.QtWidgets import (
    QWidget,
    QSlider,
    QLabel,
    QVBoxLayout,
    QGraphicsOpacityEffect,
)
from PySide6.QtCore import Qt, Signal, QTimer, QPropertyAnimation, QEasingCurve
from PySide6.QtGui import QPainter, QColor


class EdgeRevealSliderOverlay(QWidget):
    """
    Translucent right-edge overlay with a vertical slice/frame slider.

    The widget is normally invisible.  It fades in when the pointer enters
    the activation zone (right ~28 px of the viewport) and fades out after
    a short idle period or when the pointer leaves.

    Signals
    -------
    slider_value_changed : Signal(int)
        Emitted with the new 1-based slice/frame value when the user drags
        the slider.  **Not** emitted when the slider is updated programmatically
        via :meth:`set_range_and_value`.
    """

    slider_value_changed = Signal(int)

    # ------------------------------------------------------------------ #
    # Construction
    # ------------------------------------------------------------------ #

    def __init__(self, parent: QWidget) -> None:
        """
        Initialise the overlay.

        Args:
            parent: Must be the ImageViewer viewport widget so that the
                    overlay's geometry is expressed in viewport coordinates.
        """
        super().__init__(parent)

        # Translucent child — no window frame, inherits viewport background
        self.setAttribute(Qt.WidgetAttribute.WA_TranslucentBackground)
        self.setVisible(False)

        # ----- Slider -----
        self._slider = QSlider(Qt.Orientation.Vertical, self)
        self._slider.setInvertedAppearance(True)   # top = slice 1, bottom = last
        self._slider.setMinimum(1)
        self._slider.setMaximum(1)
        self._slider.setValue(1)
        self._slider.setMinimumHeight(50)
        self._slider.setStyleSheet(
            "QSlider::groove:vertical { background: rgba(255,255,255,60); width: 6px; border-radius: 3px; }"
            "QSlider::handle:vertical { background: rgba(200,200,200,220); width: 14px; height: 14px;"
            "  margin: 0 -4px; border-radius: 7px; }"
            "QSlider::sub-page:vertical { background: rgba(255,255,255,120); border-radius: 3px; }"
        )

        # ----- Label -----
        self._label = QLabel("—", self)
        self._label.setAlignment(Qt.AlignmentFlag.AlignCenter)
        self._label.setStyleSheet(
            "QLabel { color: white; font-size: 9pt; background: transparent; }"
        )
        self._label.setWordWrap(False)

        # ----- Layout -----
        layout = QVBoxLayout(self)
        layout.addWidget(self._label)
        layout.addWidget(self._slider, 1)
        layout.setContentsMargins(4, 8, 4, 8)
        layout.setSpacing(4)

        # ----- Opacity / animation -----
        self._opacity_effect = QGraphicsOpacityEffect(self)
        self._opacity_effect.setOpacity(0.0)
        self.setGraphicsEffect(self._opacity_effect)

        self._fade_anim = QPropertyAnimation(self._opacity_effect, b"opacity", self)
        self._fade_anim.setDuration(180)
        self._fade_anim.setEasingCurve(QEasingCurve.Type.InOutCubic)
        self._fade_anim.finished.connect(self._on_animation_finished)

        # ----- Auto-hide timer -----
        self._hide_timer = QTimer(self)
        self._hide_timer.setSingleShot(True)
        self._hide_timer.setInterval(1500)
        self._hide_timer.timeout.connect(self._start_fade_out)

        # ----- Internal state -----
        self._fading_out: bool = False
        self._mode_label: str = "Slice"

        # Connect slider (user interaction only — programmatic updates use blockSignals)
        self._slider.valueChanged.connect(self._on_slider_value_changed)

    # ------------------------------------------------------------------ #
    # Public API
    # ------------------------------------------------------------------ #

    def maximum(self) -> int:
        """Return the current slider maximum (== total slices/frames)."""
        return self._slider.maximum()

    def set_range_and_value(
        self,
        minimum: int,
        maximum: int,
        value: int,
        mode_label: str = "Slice",
    ) -> None:
        """
        Update slider range, current position, and label text.

        Uses ``blockSignals`` so that the ``slider_value_changed`` signal is
        **not** emitted — only genuine user interaction emits it.

        Args:
            minimum:    Lowest slider value (almost always 1).
            maximum:    Highest slider value (== total slices/frames).
            value:      Current position (1-based).
            mode_label: "Slice" or "Frame" prefix for the label.
        """
        self._mode_label = mode_label
        self._slider.blockSignals(True)
        self._slider.setMinimum(minimum)
        self._slider.setMaximum(maximum)
        self._slider.setValue(value)
        self._slider.blockSignals(False)
        self._label.setText(f"{mode_label}\n{value} / {maximum}")

    def reveal(self) -> None:
        """Fade the overlay in and restart the auto-hide countdown."""
        self._hide_timer.stop()
        self._fading_out = False

        if not self.isVisible():
            self.setVisible(True)

        current_opacity = self._opacity_effect.opacity()
        if current_opacity >= 0.99:
            # Already fully visible; just restart the hide timer
            self._hide_timer.start()
            return

        self._fade_anim.stop()
        self._fade_anim.setStartValue(current_opacity)
        self._fade_anim.setEndValue(1.0)
        self._fade_anim.start()

        self._hide_timer.start()

    def schedule_hide(self) -> None:
        """Start the auto-hide countdown (or restart it)."""
        if self._hide_timer.isActive():
            self._hide_timer.stop()
        self._hide_timer.start()

    def keep_visible(self) -> None:
        """
        Cancel the auto-hide timer while the pointer hovers over the slider.
        Call this whenever the mouse is inside the overlay geometry.
        """
        self._hide_timer.stop()
        self._fading_out = False
        # If we were fading out, snap back to fully visible
        if not self.isVisible():
            self.setVisible(True)
        if self._opacity_effect.opacity() < 0.99:
            self._fade_anim.stop()
            self._opacity_effect.setOpacity(1.0)

    # ------------------------------------------------------------------ #
    # Paint
    # ------------------------------------------------------------------ #

    def paintEvent(self, event) -> None:  # noqa: N802
        """Draw a semi-transparent dark rounded rectangle as the background."""
        painter = QPainter(self)
        painter.setRenderHint(QPainter.RenderHint.Antialiasing)
        painter.setBrush(QColor(0, 0, 0, 110))
        painter.setPen(Qt.PenStyle.NoPen)
        painter.drawRoundedRect(self.rect(), 6, 6)

    # ------------------------------------------------------------------ #
    # Private helpers
    # ------------------------------------------------------------------ #

    def _start_fade_out(self) -> None:
        """Begin the fade-out animation."""
        if self._fading_out:
            return
        self._fading_out = True
        current_opacity = self._opacity_effect.opacity()
        self._fade_anim.stop()
        self._fade_anim.setStartValue(current_opacity)
        self._fade_anim.setEndValue(0.0)
        self._fade_anim.start()

    def _on_animation_finished(self) -> None:
        """Hide the widget after a completed fade-out animation."""
        if self._fading_out and self._opacity_effect.opacity() < 0.01:
            self.setVisible(False)
            self._fading_out = False

    def _on_slider_value_changed(self, value: int) -> None:
        """Forward slider movement to the outside world (1-based index)."""
        # Update label while dragging
        maximum = self._slider.maximum()
        self._label.setText(f"{self._mode_label}\n{value} / {maximum}")
        self.slider_value_changed.emit(value)
